# =============================================================================
# ClasificaDocMuni — Variables de entorno (EJEMPLO)
# Copia este archivo a .env y completa los valores reales.
# NUNCA commitear .env con valores reales.
# =============================================================================

# ---- LLM (Qware, API OpenAI-compatible) ----
LLM_ENDPOINT=https://api.qware.me/v1
LLM_MODEL=gemini-3-flash-agent
LLM_API_KEY=tu-api-key-de-qware-aqui
LLM_RATE_LIMIT_RPM=50
LLM_TIMEOUT_SEGUNDOS=30
LLM_TEMPERATURA=0.1
LLM_MAX_TOKENS=600

# ---- Embeddings locales (búsqueda semántica) ----
EMBEDDING_MODEL=paraphrase-multilingual-MiniLM-L12-v2
EMBEDDING_DIM=384

# ---- PostgreSQL ----
POSTGRES_USER=clasifica
POSTGRES_PASSWORD=cambia-esta-clave
POSTGRES_DB=clasifica
POSTGRES_HOST=db
POSTGRES_PORT=5432

# ---- Redis ----
REDIS_HOST=redis
REDIS_PORT=6379

# ---- App ----
SECRET_KEY=genera-una-clave-larga-y-aleatoria
DATA_DIR=/var/clasifica/data
ADMIN_USERNAME=admin
ADMIN_PASSWORD=cambia-esta-clave
CORS_ORIGINS=http://localhost:8080

# ---- Workers Celery ----
CELERY_WORKERS=4
CELERY_BATCH_WORKERS=2
